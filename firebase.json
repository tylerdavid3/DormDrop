{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/bu", "destination": "/bu/index.html" },
      { "source": "/neu", "destination": "/neu/index.html" },
      { "source": "/merrimack", "destination": "/merrimack/index.html" }
    ]
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — user can read/write only their own subfolder
    match /profile-photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Listing photos — publicly readable; authenticated landlords can write
    match /listings/{landlordId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == landlordId;
    }
  }
}
